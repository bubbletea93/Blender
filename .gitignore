# Blender backup and recovery files
*.blend[0-9]
*.blend[0-9][0-9]
quit.blend
quit.blend[0-9]

# Blender caches and generated data
blendcache_*/
cache/
renders/*
!renders/gel_polish_angles/
renders/gel_polish_angles/*
!renders/gel_polish_angles/*.png

# General temporary files
*.tmp
*.temp
*.bak
*.log

# Python caches for project scripts
__pycache__/
*.py[cod]

# Extracted video frames (large binary assets)
references/lapohka_3d_motion_frames/

# Editor and OS files
.vscode/
.idea/
.vs/
.DS_Store
Thumbs.db
Desktop.ini
